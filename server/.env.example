# Copy this file to server/.env and fill in your values.
# server/.env is gitignored — never commit it.

# Long random string used to sign JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret

# Google Apps Script endpoint and API key (previously in src/sensitiveData.js)
WEB_APP_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
API_KEY=your-api-key

# Port the Express server listens on (default 3001)
PORT=3001
