# Copy this file to server/.env and fill in the values.
# server/.env is gitignored and must never be committed.

# Secret used to sign JWTs. Generate a strong random string (e.g. openssl rand -hex 32).
JWT_SECRET=change-me-to-a-long-random-secret

# Google Apps Script web app URL (from Deploy > Manage deployments in your script).
WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# API key expected by the Apps Script (set the same value in your script's properties).
API_KEY=your-api-key-here

# Port for the Express server (default: 3001).
# PORT=3001
